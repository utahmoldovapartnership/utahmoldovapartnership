---
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import '../styles/global.css'
import Navbar from '../components/Navbar.jsx'
import Footer from '../components/Footer.jsx'
import { LOCALE_META } from '../i18n/config.js'
import { getSiteData } from '../i18n/getSiteData.js'
import {
  absoluteUrl,
  breadcrumbJsonLd,
  defaultOgImage,
  jsonLdGraph,
  organizationJsonLd,
  webPageJsonLd,
  webSiteJsonLd,
} from '../data/siteSeo.js'
import { orgInfo } from '../data/siteContent.js'

const {
  title,
  description,
  heroImage,
  ogImage,
  ogType = 'website',
  noindex = false,
  breadcrumbs,
  includeWebSiteSchema = false,
  pagePath = Astro.url.pathname,
  locale = 'en',
} = Astro.props

const site = getSiteData(locale)
const htmlLang = LOCALE_META[locale]?.htmlLang ?? 'en'

const currentPath = Astro.url.pathname
const siteUrl = Astro.site?.href ?? Astro.url.origin
const canonicalUrl = new URL(pagePath, siteUrl).href
const ogImageUrl = absoluteUrl(ogImage ?? defaultOgImage, siteUrl)

const schemaEntries = [
  organizationJsonLd(siteUrl),
  includeWebSiteSchema ? webSiteJsonLd(siteUrl) : null,
  webPageJsonLd({ title, description, path: pagePath }, siteUrl),
  breadcrumbJsonLd(breadcrumbs, siteUrl),
]
const structuredData = jsonLdGraph(schemaEntries)
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="aQ03UBdqA4U_1jWItV8DvDqJiIBMII6ob5sCG-7Wyog" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large" />
    )}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={orgInfo.name} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={locale === 'ro' ? 'ro_RO' : locale === 'ru' ? 'ru_RU' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,700;0,9..144,900;1,9..144,500;1,9..144,700;1,9..144,900&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    {
      heroImage && (
        <>
          <link rel="preconnect" href={heroImage.preconnect} crossorigin />
          <link
            rel="preload"
            as="image"
            href={heroImage.src}
            fetchpriority="high"
            imagesrcset={heroImage.srcSet}
            imagesizes={heroImage.sizes}
          />
        </>
      )
    }
  </head>
  <body>
    <div
      id="umbp-flag-strip"
      class="flag-strip flag-strip--instant fixed top-0 left-0 right-0 z-[60] flex h-1"
      aria-hidden="true"
    >
      <span class="flag-strip__band flag-strip__band--blue bg-blue"></span>
      <span class="flag-strip__band flag-strip__band--yellow bg-yellow"></span>
      <span class="flag-strip__band flag-strip__band--red bg-red"></span>
    </div>
    <script is:inline>
      ;(function primeSession() {
        function pageKey() {
          var p = window.location.pathname
          if (p === '/' || p === '') return '/'
          return p.replace(/\/$/, '') || '/'
        }
        var seenKey = 'umbp:seen:' + pageKey()
        if (sessionStorage.getItem(seenKey) === '1') {
          document.documentElement.classList.add('umbp-visited')
        }
        window.addEventListener(
          'pagehide',
          function () {
            sessionStorage.setItem(seenKey, '1')
          },
          { once: true },
        )
        var strip = document.getElementById('umbp-flag-strip')
        if (!strip) return
        var last = sessionStorage.getItem('umbp:flagMode')
        if (last && last !== 'three') strip.classList.add('flag-strip--' + last)
      })()
    </script>
    <div class="min-h-screen bg-white text-ink font-sans pt-1">
      <Navbar client:load currentPath={currentPath} locale={locale} nav={site.ui.nav} orgInfo={site.orgInfo} />
      <main>
        <slot />
      </main>
      <Footer client:load locale={locale} ui={site.ui} orgInfo={site.orgInfo} />
    </div>
    <script is:inline>
      ;(function initFlagStrip() {
        const strip = document.getElementById('umbp-flag-strip')
        if (!strip) return

        const MODES = ['solo-blue', 'solo-yellow', 'solo-red']
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        function stripLocalePrefix(pathname) {
          return pathname.replace(/^\/(ro|ru)(?=\/|$)/, '') || '/'
        }

        function getTargetMode() {
          const path = stripLocalePrefix(window.location.pathname)
          if (path === '/' || path === '') {
            return sessionStorage.getItem('umbp:visited') ? 'solo-blue' : 'three'
          }
          if (path.startsWith('/interns')) return 'solo-yellow'
          if (path.startsWith('/contact')) return 'solo-red'
          return 'three'
        }

        function clearModes() {
          strip.classList.remove(...MODES.map((m) => `flag-strip--${m}`))
        }

        function applyMode(mode) {
          clearModes()
          if (mode !== 'three') strip.classList.add(`flag-strip--${mode}`)
        }

        function setInstant(on) {
          strip.classList.toggle('flag-strip--instant', on)
        }

        function forceReflow() {
          void strip.offsetWidth
        }

        function waitFrames(count) {
          return new Promise((resolve) => {
            let n = 0
            const step = () => {
              n += 1
              if (n >= count) resolve()
              else requestAnimationFrame(step)
            }
            requestAnimationFrame(step)
          })
        }

        async function transitionTo(targetMode) {
          setInstant(false)
          await waitFrames(2)
          applyMode(targetMode)
        }

        const target = getTargetMode()
        const last = sessionStorage.getItem('umbp:flagMode')

        if (reduced) {
          setInstant(true)
          applyMode(target)
          setInstant(false)
          sessionStorage.setItem('umbp:visited', '1')
          sessionStorage.setItem('umbp:flagMode', target)
          return
        }

        async function playFirstHomeIntro() {
          setInstant(true)
          applyMode('solo-red')
          setInstant(false)
          await waitFrames(2)
          applyMode('three')
        }

        async function run() {
          if (!sessionStorage.getItem('umbp:visited') && target === 'three') {
            setInstant(false)
            await playFirstHomeIntro()
            sessionStorage.setItem('umbp:visited', '1')
            sessionStorage.setItem('umbp:flagMode', 'three')
            return
          }

          sessionStorage.setItem('umbp:visited', '1')

          const startMode = last || 'three'

          if (startMode !== target) {
            setInstant(true)
            applyMode(startMode)
            forceReflow()
            setInstant(false)
            forceReflow()
            await transitionTo(target)
          } else {
            setInstant(true)
            applyMode(target)
            setInstant(false)
          }

          sessionStorage.setItem('umbp:flagMode', target)
        }

        run()
      })()
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
