---
import Layout from '../../layouts/Layout.astro'
import Contact from '../../views/Contact.jsx'
import { pageHeroImages } from '../../data/heroImages.js'
import { getPageMeta } from '../../i18n/getPageMeta.js'
import { getSiteData } from '../../i18n/getSiteData.js'

const locale = 'ru'
const seo = getPageMeta('contact', locale)
const site = getSiteData(locale)
---

<Layout
  locale={locale}
  title={seo.title}
  description={seo.description}
  pagePath={seo.path}
  ogImage={seo.ogImage}
  heroImage={pageHeroImages.contact}
  breadcrumbs={seo.breadcrumbs}
>
  <Contact client:load locale={locale} site={site} />
</Layout>
