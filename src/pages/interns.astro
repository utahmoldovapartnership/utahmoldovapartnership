---
import Layout from '../layouts/Layout.astro'
import Interns from '../views/Interns.jsx'
import { pageHeroImages } from '../data/heroImages.js'
import { pages } from '../data/siteSeo.js'

const seo = pages.interns
---

<Layout
  title={seo.title}
  description={seo.description}
  pagePath={seo.path}
  ogImage={seo.ogImage}
  breadcrumbs={seo.breadcrumbs}
  heroImage={pageHeroImages.interns}
>
  <Interns client:load />
</Layout>
