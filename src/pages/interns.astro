---
import Layout from '../layouts/Layout.astro'
import Interns from '../views/Interns.jsx'
import { pageHeroImages } from '../data/heroImages.js'

const title = 'Summer Intern Program — Utah Moldova Business Partnership'
const description =
  'Spend a summer in Chișinău with UMBP: partner with Moldovan businesses, deliver real consulting, and grow through hands-on international experience.'
