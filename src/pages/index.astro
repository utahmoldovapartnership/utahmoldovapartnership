---
import Layout from '../layouts/Layout.astro'
import Home from '../views/Home.jsx'
import { pageHeroImages } from '../data/heroImages.js'
import { getPageMeta } from '../i18n/getPageMeta.js'
import { getSiteData } from '../i18n/getSiteData.js'

const locale = 'en'
const seo = getPageMeta('home', locale)
const site = getSiteData(locale)
---

<Layout
  locale={locale}
  title={seo.title}
  description={seo.description}
  pagePath={seo.path}
  ogImage={seo.ogImage}
  heroImage={pageHeroImages.home}
  includeWebSiteSchema={true}
>
  <Home client:load locale={locale} site={site} />
</Layout>
